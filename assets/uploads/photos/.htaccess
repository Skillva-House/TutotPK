# Prevent script execution in photo uploads
Options -Indexes
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<FilesMatch "\.(php|php5|phtml|pl|py|jsp|asp|aspx|sh|cgi)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>
